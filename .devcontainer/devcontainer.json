{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "pip3 install --user -r server/requirements.txt && echo '✅ Requirements installed'",
  "postAttachCommand": {
    "server": "uvicorn server.api.app:app --reload --host 0.0.0.0 --port 8000"
  },
  "portsAttributes": {
    "8000": {
      "label": "API Server",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [8000]
}
