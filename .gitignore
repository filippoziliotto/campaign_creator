# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
.venv/
.env
*.env.*

# ── Flutter / Dart ─────────────────────────────────────────────────────────────
# Dart tool cache
app/.dart_tool/

# Flutter plugin lists (regenerated on flutter pub get)
app/.flutter-plugins
app/.flutter-plugins-dependencies

# Build output
app/build/

# Android local SDK path (machine-specific)
app/android/local.properties
app/android/.gradle/
app/android/captures/

# Android signing credentials — NEVER commit these
app/android/key.properties

# iOS CocoaPods (large, regenerated by pod install)
app/ios/Pods/
app/ios/.symlinks/

# iOS Flutter generated files (regenerated by flutter build)
app/ios/Flutter/Generated.xcconfig
app/ios/Flutter/ephemeral/
app/ios/Flutter/flutter_export_environment.sh

# macOS Flutter
app/macos/Flutter/GeneratedPluginRegistrant.swift
app/macos/Flutter/ephemeral/

# Web generated
app/web/flutter_service_worker.js
app/web/splash/

# Generated l10n (regenerated by flutter gen-l10n)
app/lib/l10n/app_localizations.dart
app/lib/l10n/app_localizations_en.dart
app/lib/l10n/app_localizations_it.dart

# ── IDE ────────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.swp
*.swo
.vscode/
docs/superpowers/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude
CLAUDE.md
docs/superpowers/
docs/.superpowers/
docs/brainstorm/
docs/.brainstorm/
.superpowers
app/android/key.properties
prova.html